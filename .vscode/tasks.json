{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "GCS: watchdog",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["tools/gcs_watchdog.py"],
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "gcs",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "GCS launcher watchdog",
          "endsPattern": "GCS launcher watchdog"
        }
      },
      "runOptions": { "runOn": "folderOpen" },
      "presentation": { "reveal": "silent", "panel": "dedicated", "showReuseMessage": false }
    }
  ]
}
